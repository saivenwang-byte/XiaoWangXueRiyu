.page { padding: 24rpx; background: #fff8e1; min-height: 100vh; }
.section { font-size: 30rpx; font-weight: 700; display: block; margin: 20rpx 0 12rpx; }
.heat { display: flex; gap: 8rpx; }
.cell { flex: 1; text-align: center; padding: 16rpx 4rpx; background: #fff; border-radius: 8rpx; font-size: 22rpx; border: 1px solid #ffccbc; }
.cell.on { background: #ff8a80; color: #fff; }
.row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1px solid #ffccbc; font-size: 28rpx; }
.hint { color: #888; font-size: 26rpx; }
.clear { margin-top: 40rpx; background: #fff; color: #6d4c41; }
