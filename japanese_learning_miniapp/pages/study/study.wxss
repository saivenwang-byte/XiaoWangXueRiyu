page {
  height: 100%;
  background: #fff8e1;
}

.study-page {
  position: relative;
  width: 100%;
  height: 100%;
}

.study-loading,
.study-fallback {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.study-logo {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
}

.study-loading-text {
  font-size: 30rpx;
  color: #546e7a;
}

.study-fallback-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #37474f;
  margin-bottom: 20rpx;
}

.study-fallback-hint {
  font-size: 28rpx;
  line-height: 1.55;
  color: #607d8b;
  margin-bottom: 16rpx;
}

.study-fallback-url {
  font-size: 22rpx;
  line-height: 1.45;
  color: #90a4ae;
  word-break: break-all;
  margin-bottom: 36rpx;
  max-width: 100%;
}

.study-retry-btn {
  width: 320rpx;
  background: #ff8a80 !important;
  color: #fff !important;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.study-fallback-legal {
  margin-top: 28rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #90a4ae;
  max-width: 100%;
}

.study-reload-fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  z-index: 9999;
}

.study-reload-fab-inner {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(55, 71, 79, 0.82);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
}
