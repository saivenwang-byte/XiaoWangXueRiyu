.page { padding: 24rpx; background: #fff8e1; min-height: 100vh; }
.line { background: #fff; border: 1px solid #ffccbc; border-radius: 12rpx; padding: 20rpx; margin-bottom: 12rpx; }
.sp { font-weight: 700; color: #e57373; margin-right: 8rpx; }
.jp { display: block; font-size: 30rpx; margin-top: 8rpx; }
.zh { display: block; font-size: 24rpx; color: #6d4c41; }
.hint { font-size: 24rpx; color: #888; display: block; margin: 24rpx 0; }
.btn { background: #ff8a80; color: #fff; }
