.container { padding: 24rpx; background: #fff8e1; min-height: 100vh; }
.card { min-height: 320rpx; background: #fff; border: 2px solid #ff8a80; border-radius: 20rpx; padding: 32rpx; }
.card-explanation { font-size: 28rpx; line-height: 1.6; }
.card-example { font-size: 32rpx; margin-top: 16rpx; }
.card-zh { font-size: 24rpx; color: #6d4c41; margin-top: 8rpx; }
.ext { margin-top: 16rpx; padding: 12rpx; border: 1px dashed #bcaaa4; border-radius: 8rpx; background: #fffde7; font-size: 24rpx; }
.ext-badge { color: #e65100; font-weight: 700; margin-right: 8rpx; }
.tags { font-size: 22rpx; color: #888; margin-top: 12rpx; }
.card-navigation { display: flex; gap: 16rpx; margin-top: 24rpx; }
.nav-button.primary { background: #ff8a80; color: #fff; }
