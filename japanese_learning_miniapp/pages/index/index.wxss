.page { padding: 24rpx; background: #fff8e1; min-height: 100vh; }
.hero { background: linear-gradient(135deg, #ff8a80, #ffab91); color: #fff; padding: 32rpx; border-radius: 24rpx; margin-bottom: 24rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; display: block; }
.hero-sub, .hero-meta { font-size: 26rpx; display: block; margin-top: 8rpx; }
.lesson-card { background: #fff; border: 1px solid #ffccbc; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; }
.lc-head { display: flex; align-items: center; gap: 12rpx; }
.lc-title { font-weight: 700; color: #e57373; font-size: 32rpx; }
.lc-badge { font-size: 22rpx; background: #fff3e0; padding: 4rpx 12rpx; border-radius: 8rpx; }
.lc-headline { font-size: 28rpx; display: block; margin: 8rpx 0; }
.lc-sub { font-size: 24rpx; color: #6d4c41; display: block; }
.lc-gates { font-size: 24rpx; display: block; margin: 12rpx 0; }
.lc-bar { height: 12rpx; background: #ffe0b2; border-radius: 6rpx; overflow: hidden; }
.lc-fill { height: 100%; background: #ff8a80; }
.btn-ghost { margin-top: 24rpx; font-size: 26rpx; color: #6d4c41; }
